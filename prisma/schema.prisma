// Prisma schema for Bonzai Payments App
// Marketplace de plantas y productos botánicos

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum TransactionStatus {
  PENDING
  HELD
  DELIVERED
  DISPUTED
  COMPLETED
  REFUNDED
}

enum LedgerType {
  DEBIT
  CREDIT
}

enum DisputeReason {
  ITEM_NOT_RECEIVED
  ITEM_DAMAGED
  ITEM_NOT_AS_DESCRIBED
  WRONG_ITEM
  QUALITY_ISSUE
  OTHER
}

enum DisputeResolution {
  FAVOR_BUYER
  FAVOR_SELLER
}

// ─── Models ──────────────────────────────────────────────

/// Sesión de cobro que agrupa múltiples transacciones (carrito de compras).
model CheckoutSession {
  id          String            @id @default(cuid())
  buyerId     String            @map("buyer_id") // Clerk user id
  totalAmount Decimal           @map("total_amount") @db.Decimal(12, 2)
  status      TransactionStatus @default(PENDING)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  transactions Transaction[]
  payments     Payment[]

  @@map("checkout_sessions")
}

/// Registro principal de cada operación de cobro/pago en el marketplace.
/// Vincula una orden (de Seller App) con el flujo financiero.
model Transaction {
  id                String            @id @default(cuid())
  checkoutSessionId String            @map("checkout_session_id")
  orderId           String            @unique @map("order_id")
  buyerId          String            @map("buyer_id") // Clerk user id
  sellerId         String            @map("seller_id") // Clerk user id
  amount           Decimal           @db.Decimal(12, 2)
  commissionRate   Decimal           @default(0.05) @map("commission_rate") @db.Decimal(5, 4)
  commissionAmount Decimal           @map("commission_amount") @db.Decimal(12, 2)
  netAmount        Decimal           @map("net_amount") @db.Decimal(12, 2)
  status           TransactionStatus @default(PENDING)
  currency         String            @default("ARS")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  ledgerEntries LedgerEntry[]
  dispute       Dispute?

  checkoutSession CheckoutSession @relation(fields: [checkoutSessionId], references: [id], onDelete: Cascade)

  @@index([buyerId])
  @@index([sellerId])
  @@index([checkoutSessionId])
  @@index([status])
  @@map("transactions")
}

/// Registro del pago procesado a través de Mercado Pago u otro proveedor.
model Payment {
  id                String @id @default(cuid())
  checkoutSessionId String @map("checkout_session_id")
  provider        String @default("MERCADOPAGO")
  providerStatus  String? @map("provider_status")
  externalId      String? @unique @map("external_id")
  idempotencyKey  String @unique @default(cuid()) @map("idempotency_key")
  checkoutUrl     String? @map("checkout_url")
  preferenceId    String? @map("preference_id")
  createdAt       DateTime @default(now()) @map("created_at")

  checkoutSession CheckoutSession @relation(fields: [checkoutSessionId], references: [id], onDelete: Cascade)

  @@index([checkoutSessionId])
  @@map("payments")
}

/// Entrada del libro mayor (ledger) para auditoría contable.
/// Cada movimiento financiero genera al menos un DEBIT y un CREDIT.
model LedgerEntry {
  id            String     @id @default(cuid())
  userId        String     @map("user_id") // Clerk user id
  transactionId String     @map("transaction_id")
  type          LedgerType
  amount        Decimal    @db.Decimal(12, 2)
  description   String?
  createdAt     DateTime   @default(now()) @map("created_at")

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([transactionId])
  @@map("ledger_entries")
}

/// Billetera virtual de cada usuario (vendedor).
/// Consolida saldo disponible y retenido.
model Wallet {
  id               String   @id @default(cuid())
  userId           String   @unique @map("user_id") // Clerk user id
  availableBalance Decimal  @default(0) @map("available_balance") @db.Decimal(12, 2)
  heldBalance      Decimal  @default(0) @map("held_balance") @db.Decimal(12, 2)
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("wallets")
}

/// Registro de disputas sobre transacciones.
model Dispute {
  id              String             @id @default(cuid())
  transactionId   String             @unique @map("transaction_id")
  reason          DisputeReason
  description     String?
  resolution      DisputeResolution?
  resolutionNotes String?            @map("resolution_notes")
  refundAmount    Decimal?           @map("refund_amount") @db.Decimal(12, 2)
  createdAt       DateTime           @default(now()) @map("created_at")
  resolvedAt      DateTime?          @map("resolved_at")

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@map("disputes")
}
